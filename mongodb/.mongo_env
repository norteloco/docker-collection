MONGO_INITDB_ROOT_USERNAME_FILE=/run/secrets/ROOT_USERNAME
MONGO_INITDB_ROOT_PASSWORD_FILE=/run/secrets/ROOT_PASSWORD

ME_CONFIG_MONGODB_SERVER=mongodb
ME_CONFIG_MONGODB_PORT=27017
ME_CONFIG_MONGODB_ENABLE_ADMIN=true
ME_CONFIG_MONGODB_ADMINUSERNAME_FILE=/run/secrets/ROOT_USERNAME
ME_CONFIG_MONGODB_ADMINPASSWORD_FILE=/run/secrets/ROOT_PASSWORD  # ← не USERNAME!
ME_CONFIG_BASICAUTH_ENABLED=true
ME_CONFIG_BASICAUTH_USERNAME_FILE=/run/secrets/BASIC_USERNAME
ME_CONFIG_BASICAUTH_PASSWORD_FILE=/run/secrets/BASIC_PASSWORD