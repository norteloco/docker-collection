## Paths
GF_PATHS_DATA=/var/lib/grafana
GF_PATH_LOGS=/var/log/grafana

## Server 
GF_SERVER_PROTOCOL=http
GF_SERVER_ROOT_URL=%(protocol)s://%(domain)s/
GF_SERVER_DOMAIN=grafana.example.local
GF_SERVER_ENABLE_GZIP=true

## Analytics
GF_ANALYTICS_CHECK_FOR_PLUGIN_UPDATES=true

## Security
GF_SECURITY_DISABLE_INITIAL_ADMIN_CREATION=false
GF_SECURITY_ADMIN_USER__FILE=/run/secrets/ADMIN_USER
GF_SECURITY_ADMIN_PASSWORD__FILE=/run/secrets/ADMIN_PASSWORD

## Plugins
GF_INSTALL_IMAGE_RENDERER_PLUGIN=true

## Dashboards
GF_DASHBOARDS_VERSIONS_TO_KEEP=10

## Users
GF_USERS_ALLOW_SIGN_UP=false
GF_USERS_DEFAULT_THEME=dark

## Authorization
GF_AUTH_ANONYMOUS_ENABLED=false
GF_AUTH_ANONYMOUS_DISABLE_LOGIN_FORM=false
GF_AUTH_BASIC_ENABLED=true
GF_AUTH_LOGIN_MAXIMUM_INACTIVE_LIFETIME_DURATION=24h

## Logs
GF_LOG_MODE=console file
GF_LOG_LEVEL=info